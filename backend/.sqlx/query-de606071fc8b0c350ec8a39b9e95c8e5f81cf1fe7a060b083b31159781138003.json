  "db_name": "PostgreSQL",
  "query": "\n        SELECT \n          id, \n          owner_user_id, \n          parent_id, \n          name, \n          node_type, \n          status, \n          deleted_at, \n          created_at, \n          updated_at\n\n        FROM nodes\n\n        WHERE owner_user_id = $1 \n          AND parent_id = $2\n          AND deleted_at IS NULL AND status = 'active'\n\n        ORDER BY node_type DESC, name ASC\n        ",
