  "db_name": "PostgreSQL",
  "query": "\n      SELECT \n        id, \n        owner_user_id, \n        parent_id, \n        name, \n        node_type, \n        status, \n        deleted_at, \n        created_at, \n        updated_at\n      FROM\n        nodes\n      WHERE\n        owner_user_id = $1 \n        AND parent_id IS NULL \n        AND deleted_at IS NULL \n        AND status = 'active' \n      ORDER BY\n        node_type DESC,\n        name ASC\n      ",
