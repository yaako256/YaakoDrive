{
  "db_name": "PostgreSQL",
  "query": "\n      SELECT\n        id,\n        owner_user_id,\n        parent_id,\n        name,\n        node_type,\n        status,\n        deleted_at,\n        created_at,\n        updated_at\n      FROM nodes\n      WHERE\n        owner_user_id = $1\n        AND deleted_at IS NOT NULL\n        AND (\n        parent_id IS NULL\n          OR EXISTS (\n            SELECT 1 FROM nodes p\n            WHERE p.id = nodes.parent_id\n              AND p.deleted_at IS NULL\n        )\n      )\n      ORDER BY deleted_at DESC\n      ",
