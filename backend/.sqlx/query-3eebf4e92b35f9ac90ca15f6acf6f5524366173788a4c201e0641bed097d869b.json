  "query": "\n      SELECT\n        id,\n        owner_user_id,\n        parent_id,\n        name,\n        node_type,\n        status,\n        deleted_at,\n        created_at,\n        updated_at\n      FROM nodes\n      WHERE\n        owner_user_id = $1\n        AND parent_id = $2\n        AND deleted_at IS NOT NULL\n      ORDER BY node_type DESC, name ASC\n      ",
